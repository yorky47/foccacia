@BASE_URL = http://localhost:3000
@USER_TOKEN = 725b7c84-31c0-4ba1-ac33-8b7690e9b681
@GROUP_ID = 1
//
### 1. Criar Utilizador
POST {{BASE_URL}}/api/users 
Content-Type: application/json

{
    "username": "arsenal-user-test"
}

### 2. Criar Grupo (PL 2025) - Para testar limite de 11 jogadores
POST {{BASE_URL}}/api/groups 
Authorization: Bearer {{USER_TOKEN}}
Content-Type: application/json

{
    "name": "Arsenal Squad 2025",
    "description": "Test group to verify 11 player limit",
    "competition": "PL",
    "year": 2025
}

### 3. Adicionar Jogador 1 de 11
POST {{BASE_URL}}/api/groups/{{GROUP_ID}}/players
Authorization: Bearer {{USER_TOKEN}}
X-Auth-Token: {{KEY}}
Content-Type: application/json

{
    "playerId": 3189,
    "playerName": "Kepa Arrizabalaga",
    "position": "Goalkeeper",
    "nationality": "Spain"
}

