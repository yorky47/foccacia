<div class="row">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="bi bi-list-ul"></i> My Groups
            </h2>
            <a href="/site/groups/new" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New Group
            </a>
        </div>

        {{#if groups.length}}
            <div class="row">
                {{#each groups}}
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <i class="bi bi-trophy-fill text-warning"></i>
                                    {{this.name}}
                                </h5>
                                <p class="card-text text-muted small">{{this.description}}</p>
                                
                                <div class="mb-3">
                                    <span class="badge bg-primary">{{this.competition}}</span>
                                    <span class="badge bg-secondary">{{this.year}}</span>
                                </div>

                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted">
                                        <i class="bi bi-people-fill"></i>
                                        {{this.players.length}}/11 players
                                    </span>
                                    <a href="/site/groups/{{this.id}}" class="btn btn-sm btn-outline-primary">
                                        View Details <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {{/each}}
            </div>
        {{else}}
            <div class="card p-5 text-center">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <h4 class="mt-3 mb-3">No groups yet</h4>
                <p class="text-muted">Create your first football squad to get started!</p>
                <div class="mt-3">
                    <a href="/site/groups/new" class="btn btn-primary btn-lg">
                        <i class="bi bi-plus-circle"></i> Create Your First Group
                    </a>
                </div>
            </div>
        {{/if}}
    </div>
</div>
