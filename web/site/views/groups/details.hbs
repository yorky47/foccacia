<div class="row">
    <div class="col-md-12">
        <div class="card mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h2 class="card-title mb-2">
                            <i class="bi bi-trophy-fill text-warning"></i>
                            {{group.name}}
                        </h2>
                        <p class="text-muted">{{group.description}}</p>
                        <div>
                            <span class="badge bg-primary me-2">{{group.competition}}</span>
                            <span class="badge bg-secondary">Season {{group.year}}</span>
                        </div>
                    </div>
                    <div class="btn-group">
                        <a href="/site/groups/{{group.id}}/update" class="btn btn-outline-primary">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a href="/site/groups" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    </div>
                </div>
            </div>
        </div>

        {{#if error}}
            <div class="alert alert-danger">{{error}}</div>
        {{/if}}

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-people-fill"></i>
                    Squad Players ({{group.players.length}}/11)
                </h5>
                {{#if (lt group.players.length 11)}}
                    <a class="btn btn-sm btn-primary" href="#add-player">
                        <i class="bi bi-plus-circle"></i> Add Player
                    </a>
                {{/if}}
            </div>
            <div class="card-body">
                {{#if group.players.length}}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Player</th>
                                    <th>Position</th>
                                    <th>Nationality</th>
                                    <th>Team</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each group.players}}
                                    <tr>
                                        <td>{{@index}}</td>
                                        <td>
                                            <i class="bi bi-person-fill text-primary"></i>
                                            <strong>{{this.name}}</strong>
                                        </td>
                                        <td>{{this.position}}</td>
                                        <td>{{this.nationality}}</td>
                                        <td>{{this.teamName}}</td>
                                        <td>
                                            <form action="/site/groups/{{../group.id}}/players/{{this.id}}/delete" method="POST" style="display:inline;">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove Player">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                {{else}}
                    <div class="text-center py-5">
                        <i class="bi bi-inbox display-3 text-muted"></i>
                        <h5 class="mt-3 text-muted">No players yet</h5>
                        <a class="btn btn-primary mt-2" href="#add-player">
                            <i class="bi bi-plus-circle"></i> Add Your First Player
                        </a>
                    </div>
                {{/if}}
            </div>
        </div>

        {{#if (lt group.players.length 11)}}
            <div class="card mt-4" id="add-player">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-plus-circle"></i>
                        Add Player
                    </h5>
                </div>
                <div class="card-body">
                    {{#if teams.length}}
                        <p class="text-muted mb-3">Click on a team to expand its player list:</p>

                        {{#each teams}}
                            <details class="mb-2 border rounded">
                                <summary class="p-3 bg-light d-flex justify-content-between align-items-center" style="cursor: pointer;">
                                    <div>
                                        <strong>{{this.name}}</strong>
                                        <span class="text-muted ms-2">({{this.country}})</span>
                                    </div>
                                    <i class="bi bi-chevron-down text-muted"></i>
                                </summary>
                                <div class="p-3">
                                    <div class="table-responsive">
                                        <table class="table table-sm">
                                            <thead>
                                                <tr>
                                                    <th>Name</th>
                                                    <th>Position</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {{#each this.players}}
                                                    <tr>
                                                        <td>{{this.playerName}}</td>
                                                        <td>{{this.position}}</td>
                                                        <td class="text-end">
                                                            <form action="/site/groups/{{@root.group.id}}/players" method="POST">
                                                                <input type="hidden" name="playerId" value="{{this.playerId}}">
                                                                <button type="submit" class="btn btn-sm btn-primary">Add</button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                {{/each}}
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </details>
                        {{/each}}
                    {{else}}
                        <div class="alert alert-warning mb-0">
                            No teams available for {{group.competition}} {{group.year}}.
                        </div>
                    {{/if}}
                </div>
            </div>
        {{/if}}
    </div>
</div>
