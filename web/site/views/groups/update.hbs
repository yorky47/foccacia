<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-pencil-square"></i> Edit Group</h2>
                
                <form action="/site/groups/{{formData.id}}/delete" method="POST" onsubmit="return confirm('Are you sure?');">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete Group
                    </button>
                </form>
            </div>

            {{#if error}}
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i> {{error}}
                </div>
            {{/if}}

            <form method="POST" action="/site/groups/{{formData.id}}/update">
                <div class="mb-3">
                    <label for="name" class="form-label">Group Name *</label>
                    <input type="text" class="form-control" id="name" name="name" 
                           required minlength="3" value="{{formData.name}}">
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea class="form-control" id="description" name="description" rows="3">{{formData.description}}</textarea>
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Competition</label>
                        <input type="text" class="form-control" value="{{formData.competition}}" disabled readonly>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Season Year</label>
                        <input type="text" class="form-control" value="{{formData.year}}" disabled readonly>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a href="/site/groups/{{formData.id}}" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>